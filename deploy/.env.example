# =============================================================================
# /opt/boyzera/.env on the EC2 server
# Copy to /opt/boyzera/.env and fill in real values. NEVER commit /opt/boyzera/.env.
# =============================================================================

# Identifies the GHCR namespace (your GitHub user or org, lowercase).
IMAGE_OWNER=<your-github-owner>
IMAGE_TAG=latest

# ---- Runtime ----
NODE_ENV=production
PORT=5001
RUN_MIGRATIONS=true

# ---- Database (PostgreSQL — runs in compose as service name `postgres`) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=boyzera
POSTGRES_PASSWORD=<rotate-and-fill>
POSTGRES_DB=boyzera
DB_SSL=false

# ---- Cache (Redis — runs in compose as service name `redis`) ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Auth ----
# Generate with: openssl rand -base64 48
JWT_SECRET=<rotate-and-fill>

# ---- Frontend / CORS ----
FRONTEND_URL=https://boyzera-frontend.vercel.app

# ---- Telegram ----
# Rotate via @BotFather before reusing on production.
TELEGRAM_BOT_TOKEN=<rotate-and-fill>
TELEGRAM_BOT_USERNAME=boyzueira_test_bot

# ---- Rate limit ----
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# ---- Game config ----
MAX_TAPS_PER_SECOND=20
COMBO_TIMEOUT_MS=1000
COMBO_MAX_MULTIPLIER=5
OFFLINE_MAX_HOURS=3
ANTI_CHEAT_ENABLED=true

# ---- SMTP (optional — leave blank to disable email) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
