# Build artifacts
**/node_modules
**/dist
**/coverage
**/.next
**/.turbo

# Local env / secrets — never bake into images
**/.env
**/.env.*
!**/.env.example

# VCS / IDE / OS
.git
.gitignore
.github
.vscode
.idea
.DS_Store

# Logs and tmp
*.log
*.tmp
*.swp

# Docs / planning that don't ship in the image
*.md
docs/
.planning/

# Frontend — backend image doesn't need it
apps/frontend
